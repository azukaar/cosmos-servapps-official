{
  "cosmos-installer": {
    "form": [
      {
        "name": "adminEmail",
        "label": "Admin email (auto-promoted to superadmin on first login)",
        "initialValue": "",
        "type": "text"
      }
    ]
  },
  "minVersion": "0.13.0",
  "services": {
    "{ServiceName}": {
      "image": "drumsergio/lynxprompt:latest",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "environment": [
        "NODE_ENV=production",
        "DB_APP_HOST={ServiceName}-db",
        "DB_APP_USER=lynxprompt",
        "DB_APP_PASSWORD={Passwords.0}",
        "DB_APP_NAME=lynxprompt",
        "DB_USERS_HOST={ServiceName}-db",
        "DB_USERS_USER=lynxprompt",
        "DB_USERS_PASSWORD={Passwords.0}",
        "DB_USERS_NAME=lynxprompt",
        "DB_BLOG_HOST={ServiceName}-db",
        "DB_BLOG_USER=lynxprompt",
        "DB_BLOG_PASSWORD={Passwords.0}",
        "DB_BLOG_NAME=lynxprompt",
        "DB_SUPPORT_HOST={ServiceName}-db",
        "DB_SUPPORT_USER=lynxprompt",
        "DB_SUPPORT_PASSWORD={Passwords.0}",
        "DB_SUPPORT_NAME=lynxprompt",
        "NEXTAUTH_SECRET={Passwords.1}",
        "NEXTAUTH_URL=http://localhost:3000",
        "APP_URL=http://localhost:3000",
        "SUPERADMIN_EMAIL={Context.adminEmail}"
      ],
      "labels": {
        "cosmos-persistent-env": "DB_APP_PASSWORD, DB_USERS_PASSWORD, DB_BLOG_PASSWORD, DB_SUPPORT_PASSWORD, NEXTAUTH_SECRET, NEXTAUTH_URL, APP_URL, SUPERADMIN_EMAIL",
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/LynxPrompt/icon.png",
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "networks": {
        "{ServiceName}-network": {}
      },
      "depends_on": [
        "{ServiceName}-db"
      ],
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose {ServiceName} to the web",
          "useHost": true,
          "target": "http://{ServiceName}:3000",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    },
    "{ServiceName}-db": {
      "image": "postgres:17-alpine",
      "container_name": "{ServiceName}-db",
      "hostname": "{ServiceName}-db",
      "restart": "unless-stopped",
      "volumes": [
        {
          "source": "{ServiceName}-db-data",
          "target": "/var/lib/postgresql/data",
          "type": "volume"
        }
      ],
      "environment": [
        "POSTGRES_DB=lynxprompt",
        "POSTGRES_USER=lynxprompt",
        "POSTGRES_PASSWORD={Passwords.0}"
      ],
      "labels": {
        "cosmos-persistent-env": "POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD",
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "networks": {
        "{ServiceName}-network": {}
      }
    }
  },
  "networks": {
    "{ServiceName}-network": {}
  }
}
