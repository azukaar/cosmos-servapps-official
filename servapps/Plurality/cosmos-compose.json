{
  "cosmos-installer": {
    "form": [
      {
        "name": "OPENROUTER_API_KEY",
        "label": "Your OpenRouter API key (OPTIONAL: if you want to use a different provider, see Plurality's documentation for setup)",
        "initialValue": "",
        "type": "text"
      },
      {
        "name": "PERSIST_VOL",
        "label": "Path to a host folder Plurality can persist and share files in. It is bind-mounted at the same path inside the container so paths stay consistent. (leave empty to not mount anything)",
        "initialValue": "{DefaultDataPath}/plurality",
        "type": "text"
      }
    ]
  },
  "minVersion": "0.22.23",
  "services": {
    "{ServiceName}": {
      "image": "azukaar/plurality",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "environment": [
        "OPENROUTER_API_KEY={Context.OPENROUTER_API_KEY}",
        "OPENID_ISSUER={RootProtocol}://{RootHostname}",
        "OPENID_NAME=Cosmos",
        "OPENID_CLIENT_ID={ServiceName}",
        "OPENID_BTN_COLOR=#FFFFFF",
        "OPENID_BTN_BG1=#FF64C8",
        "OPENID_BTN_BG2=#C864FF",
        "PERSIST_VOL={Context.PERSIST_VOL}",
        "WEBHOOK_EXT={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}"
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Plurality/icon.png",
        "cosmos-persistent-env": "OPENROUTER_API_KEY, PERSIST_VOL, OPENID_ISSUER"
      },
      "volumes": [
        {
          "source": "{ServiceName}-data",
          "target": "/app/data",
          "type": "volume"
        },
        {
          "source": "{ServiceName}-users",
          "target": "/app/users-data",
          "type": "volume"
        }
        {if Context.PERSIST_VOL}
        , {
          "source": "{Context.PERSIST_VOL}",
          "target": "{Context.PERSIST_VOL}",
          "type": "bind"
        }
        {/if}
      ],
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose {ServiceName} to the web",
          "useHost": true,
          "target": "http://{ServiceName}:8090",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    }
  }
}
