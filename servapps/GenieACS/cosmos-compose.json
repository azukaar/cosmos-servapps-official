{
  "minVersion": "0.13.0",
  "services": {
    "{ServiceName}": {
      "image": "drumsergio/genieacs:latest",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "environment": [
        "TZ=auto",
        "GENIEACS_MONGODB_CONNECTION_URL=mongodb://{ServiceName}-db:27017/genieacs",
        "GENIEACS_UI_JWT_SECRET={Passwords.0}"
      ],
      "ports": [
        "7547:7547",
        "7557:7557",
        "7567:7567"
      ],
      "labels": {
        "cosmos-persistent-env": "GENIEACS_MONGODB_CONNECTION_URL, GENIEACS_UI_JWT_SECRET",
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/GenieACS/icon.png",
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "networks": {
        "{ServiceName}-network": {}
      },
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose {ServiceName} Web UI",
          "useHost": true,
          "target": "http://{ServiceName}:3000",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    },
    "{ServiceName}-db": {
      "image": "mongo:8.0",
      "container_name": "{ServiceName}-db",
      "hostname": "{ServiceName}-db",
      "restart": "unless-stopped",
      "volumes": [
        {
          "source": "{ServiceName}-db-data",
          "target": "/data/db",
          "type": "volume"
        }
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "networks": {
        "{ServiceName}-network": {}
      }
    }
  },
  "networks": {
    "{ServiceName}-network": {}
  }
}
