{
  "cosmos-installer": {
    "skip-default-network": true
  },
  "minVersion": "0.22.23",
  "networks": {
    "{ServiceName}_default": {
      "driver": "bridge",
      "attachable": true,
      "labels": {
        "com.docker.compose.network": "default",
        "com.docker.compose.project": "{ServiceName}"
      }
    }
  },
  "services": {
    "{ServiceName}": {
      "image": "nginx:1.29-alpine",
      "container_name": "{ServiceName}",
      "hostname": "{ServiceName}",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "nginx"
          ]
        }
      },
      "restart": "unless-stopped",
      "entrypoint": "/bin/sh -c",
      "command": "printf$IFS'%s'$IFS''|base64$IFS'-d'>'/etc/nginx/nginx.conf';P='{'ServiceName'}';sed$IFS'-i'$IFS\"s/$P/$NORA_SERVICE_NAME/g\"$IFS'/etc/nginx/nginx.conf';G=daemon$IFS'off;';exec$IFS'nginx'$IFS'-g'$IFS\"$G\"",
      "environment": [
        "NORA_SERVICE_NAME={ServiceName}"
      ],
      "expose": [
        "80"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png"
      },
      "depends_on": {
        "{ServiceName}-backend-api": {},
        "{ServiceName}-frontend-marketing": {},
        "{ServiceName}-frontend-dashboard": {},
        "{ServiceName}-admin-dashboard": {}
      },
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose Nora through Cosmos",
          "useHost": true,
          "target": "http://{ServiceName}:80",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": false,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    },
    "{ServiceName}-frontend-marketing": {
      "image": "ghcr.io/solomon2773/nora-frontend-marketing:v1.15.0@sha256:688f2fe9eb34b4474ba57a74b021625e9c7d53d07ae50d2bb81ed710b655b45a",
      "container_name": "{ServiceName}-frontend-marketing",
      "hostname": "{ServiceName}-frontend-marketing",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "frontend-marketing"
          ]
        }
      },
      "restart": "unless-stopped",
      "environment": [
        "PORT=3000",
        "NODE_ENV=production",
        "PLATFORM_MODE=selfhosted"
      ],
      "expose": [
        "3000"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png"
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:3000/ >/dev/null || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 20
      }
    },
    "{ServiceName}-frontend-dashboard": {
      "image": "ghcr.io/solomon2773/nora-frontend-dashboard:v1.15.0@sha256:84b866e1c71103c3def7d689987dc4d662eab9a55b2377a6ce35ec7c19f7f3e0",
      "container_name": "{ServiceName}-frontend-dashboard",
      "hostname": "{ServiceName}-frontend-dashboard",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "frontend-dashboard"
          ]
        }
      },
      "restart": "unless-stopped",
      "environment": [
        "PORT=3000",
        "NODE_ENV=production"
      ],
      "expose": [
        "3000"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png"
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:3000/app >/dev/null || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 20
      }
    },
    "{ServiceName}-admin-dashboard": {
      "image": "ghcr.io/solomon2773/nora-admin-dashboard:v1.15.0@sha256:cec4912741a61c535e78656745421cff9554f70887021090af09034e954966ac",
      "container_name": "{ServiceName}-admin-dashboard",
      "hostname": "{ServiceName}-admin-dashboard",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "admin-dashboard"
          ]
        }
      },
      "restart": "unless-stopped",
      "environment": [
        "PORT=3000",
        "NODE_ENV=production"
      ],
      "expose": [
        "3000"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png"
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:3000/admin >/dev/null || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 20
      }
    },
    "{ServiceName}-backend-api": {
      "image": "ghcr.io/solomon2773/nora-backend-api:v1.15.0@sha256:cff8af667cee92a221bfe151873fca7f28b56d33ee45cda014c299f03a2ca896",
      "container_name": "{ServiceName}-backend-api",
      "hostname": "{ServiceName}-backend-api",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "backend-api"
          ]
        }
      },
      "restart": "unless-stopped",
      "entrypoint": "/bin/sh -c",
      "command": "export$IFS'ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_ENCRYPTION_SEED\"|sha256sum|cut$IFS'-c1-64');export$IFS'NORA_BACKUP_ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_BACKUP_SEED\"|sha256sum|cut$IFS'-c1-64');node$IFS'-e'$IFS'const{Pool}=require(\"pg\"),fs=require(\"fs\"),p=new/**/Pool({host:process.env.DB_HOST,port:Number(process.env.DB_PORT),user:process.env.DB_USER,password:process.env.DB_PASSWORD,database:process.env.DB_NAME});(async()=>{for(;;){try{await/**/p.query(fs.readFileSync(\"/app/db_schema.sql\",\"utf8\"));await/**/p.end();break}catch(e){console.error(\"waiting_for_database:\",e.message);await/**/new/**/Promise(r=>setTimeout(r,2000))}}})().catch(e=>{console.error(e);process.exit(1)})';exec$IFS'npm'$IFS'start'",
      "environment": [
        "NODE_ENV=production",
        "PLATFORM_MODE=selfhosted",
        "ENABLED_BACKENDS=docker",
        "ENABLED_RUNTIME_FAMILIES=openclaw,hermes",
        "ENABLED_SANDBOX_PROFILES=standard",
        "OPENCLAW_DOCKER_IMAGE=node:24-slim",
        "NEXTAUTH_URL={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "CORS_ORIGINS={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "DB_HOST={ServiceName}-postgres",
        "DB_PORT=5432",
        "DB_USER=nora",
        "DB_PASSWORD={Passwords.3}",
        "DB_NAME=nora",
        "REDIS_HOST={ServiceName}-redis",
        "REDIS_PORT=6379",
        "JWT_SECRET={Passwords.0}{Passwords.1}",
        "NORA_API_KEY_HASH_SECRET={Passwords.3}{Passwords.0}",
        "NORA_AGENT_HUB_API_KEY_HASH_SECRET={Passwords.2}{Passwords.0}",
        "NORA_ENCRYPTION_SEED={Passwords.1}{Passwords.2}",
        "NORA_BACKUP_SEED={Passwords.2}{Passwords.3}",
        "NORA_INSTALL_METHOD=docker_image",
        "NORA_CURRENT_VERSION=v1.15.0",
        "NORA_GITHUB_REPO=solomon2773/nora",
        "NORA_AUTO_UPGRADE_ENABLED=false",
        "NORA_BACKUP_STORAGE=local",
        "NORA_BACKUP_DIR=/var/lib/nora-backups",
        "PORT=4000"
      ],
      "expose": [
        "4000"
      ],
      "extra_hosts": [
        "host.docker.internal:host-gateway"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png",
        "cosmos-persistent-env": "JWT_SECRET,NORA_API_KEY_HASH_SECRET,NORA_AGENT_HUB_API_KEY_HASH_SECRET,NORA_ENCRYPTION_SEED,NORA_BACKUP_SEED,DB_PASSWORD"
      },
      "volumes": [
        {
          "source": "/var/run/docker.sock",
          "target": "/var/run/docker.sock",
          "type": "bind"
        },
        {
          "source": "{ServiceName}-upgrade-state",
          "target": "/var/lib/nora-upgrade",
          "type": "volume"
        },
        {
          "source": "{ServiceName}-backups",
          "target": "/var/lib/nora-backups",
          "type": "volume"
        }
      ],
      "depends_on": {
        "{ServiceName}-postgres": {},
        "{ServiceName}-redis": {}
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://127.0.0.1:4000/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\""
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 30
      }
    },
    "{ServiceName}-worker-provisioner": {
      "image": "ghcr.io/solomon2773/nora-worker-provisioner:v1.15.0@sha256:163500508bc3cb53d5ac5e03dd5f54dae3168c9965e89894d4869743d01af763",
      "container_name": "{ServiceName}-worker-provisioner",
      "hostname": "{ServiceName}-worker-provisioner",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "worker-provisioner"
          ]
        }
      },
      "restart": "unless-stopped",
      "entrypoint": "/bin/sh -c",
      "command": "export$IFS'ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_ENCRYPTION_SEED\"|sha256sum|cut$IFS'-c1-64');export$IFS'NORA_BACKUP_ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_BACKUP_SEED\"|sha256sum|cut$IFS'-c1-64');exec$IFS'npm'$IFS'start'",
      "environment": [
        "NODE_ENV=production",
        "PLATFORM_MODE=selfhosted",
        "ENABLED_BACKENDS=docker",
        "ENABLED_RUNTIME_FAMILIES=openclaw,hermes",
        "ENABLED_SANDBOX_PROFILES=standard",
        "OPENCLAW_DOCKER_IMAGE=node:24-slim",
        "NEXTAUTH_URL={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "CORS_ORIGINS={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "DB_HOST={ServiceName}-postgres",
        "DB_PORT=5432",
        "DB_USER=nora",
        "DB_PASSWORD={Passwords.3}",
        "DB_NAME=nora",
        "REDIS_HOST={ServiceName}-redis",
        "REDIS_PORT=6379",
        "JWT_SECRET={Passwords.0}{Passwords.1}",
        "NORA_API_KEY_HASH_SECRET={Passwords.3}{Passwords.0}",
        "NORA_AGENT_HUB_API_KEY_HASH_SECRET={Passwords.2}{Passwords.0}",
        "NORA_ENCRYPTION_SEED={Passwords.1}{Passwords.2}",
        "NORA_BACKUP_SEED={Passwords.2}{Passwords.3}",
        "NORA_INSTALL_METHOD=docker_image",
        "NORA_CURRENT_VERSION=v1.15.0",
        "NORA_GITHUB_REPO=solomon2773/nora",
        "NORA_AUTO_UPGRADE_ENABLED=false",
        "NORA_BACKUP_STORAGE=local",
        "NORA_BACKUP_DIR=/var/lib/nora-backups",
        "DEPLOYMENT_WORKER_CONCURRENCY=6",
        "NODE_PATH=/app/node_modules"
      ],
      "extra_hosts": [
        "host.docker.internal:host-gateway"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png",
        "cosmos-persistent-env": "JWT_SECRET,NORA_API_KEY_HASH_SECRET,NORA_AGENT_HUB_API_KEY_HASH_SECRET,NORA_ENCRYPTION_SEED,NORA_BACKUP_SEED,DB_PASSWORD"
      },
      "volumes": [
        {
          "source": "/var/run/docker.sock",
          "target": "/var/run/docker.sock",
          "type": "bind"
        }
      ],
      "depends_on": {
        "{ServiceName}-backend-api": {},
        "{ServiceName}-postgres": {},
        "{ServiceName}-redis": {}
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://127.0.0.1:4001/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\""
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 30
      }
    },
    "{ServiceName}-worker-backup": {
      "image": "ghcr.io/solomon2773/nora-worker-backup:v1.15.0@sha256:60c35d6932f5d08e461750142ff5c4211a0be9aa29dbc5172a28ba55cbee6222",
      "container_name": "{ServiceName}-worker-backup",
      "hostname": "{ServiceName}-worker-backup",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "worker-backup"
          ]
        }
      },
      "restart": "unless-stopped",
      "entrypoint": "/bin/sh -c",
      "command": "export$IFS'ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_ENCRYPTION_SEED\"|sha256sum|cut$IFS'-c1-64');export$IFS'NORA_BACKUP_ENCRYPTION_KEY'=$(printf$IFS'%s'$IFS\"$NORA_BACKUP_SEED\"|sha256sum|cut$IFS'-c1-64');exec$IFS'npm'$IFS'start'",
      "environment": [
        "NODE_ENV=production",
        "PLATFORM_MODE=selfhosted",
        "ENABLED_BACKENDS=docker",
        "ENABLED_RUNTIME_FAMILIES=openclaw,hermes",
        "ENABLED_SANDBOX_PROFILES=standard",
        "OPENCLAW_DOCKER_IMAGE=node:24-slim",
        "NEXTAUTH_URL={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "CORS_ORIGINS={RootProtocol}://{Hostnames.{StaticServiceName}.{StaticServiceName}.host}",
        "DB_HOST={ServiceName}-postgres",
        "DB_PORT=5432",
        "DB_USER=nora",
        "DB_PASSWORD={Passwords.3}",
        "DB_NAME=nora",
        "REDIS_HOST={ServiceName}-redis",
        "REDIS_PORT=6379",
        "JWT_SECRET={Passwords.0}{Passwords.1}",
        "NORA_API_KEY_HASH_SECRET={Passwords.3}{Passwords.0}",
        "NORA_AGENT_HUB_API_KEY_HASH_SECRET={Passwords.2}{Passwords.0}",
        "NORA_ENCRYPTION_SEED={Passwords.1}{Passwords.2}",
        "NORA_BACKUP_SEED={Passwords.2}{Passwords.3}",
        "NORA_INSTALL_METHOD=docker_image",
        "NORA_CURRENT_VERSION=v1.15.0",
        "NORA_GITHUB_REPO=solomon2773/nora",
        "NORA_AUTO_UPGRADE_ENABLED=false",
        "NORA_BACKUP_STORAGE=local",
        "NORA_BACKUP_DIR=/var/lib/nora-backups",
        "BACKUP_WORKER_CONCURRENCY=2",
        "NODE_PATH=/app/node_modules"
      ],
      "extra_hosts": [
        "host.docker.internal:host-gateway"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png",
        "cosmos-persistent-env": "JWT_SECRET,NORA_API_KEY_HASH_SECRET,NORA_AGENT_HUB_API_KEY_HASH_SECRET,NORA_ENCRYPTION_SEED,NORA_BACKUP_SEED,DB_PASSWORD"
      },
      "volumes": [
        {
          "source": "/var/run/docker.sock",
          "target": "/var/run/docker.sock",
          "type": "bind"
        },
        {
          "source": "{ServiceName}-backups",
          "target": "/var/lib/nora-backups",
          "type": "volume"
        }
      ],
      "depends_on": {
        "{ServiceName}-backend-api": {},
        "{ServiceName}-postgres": {},
        "{ServiceName}-redis": {}
      },
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://127.0.0.1:4002/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\""
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "start_period": 30
      }
    },
    "{ServiceName}-postgres": {
      "image": "postgres:15-alpine",
      "container_name": "{ServiceName}-postgres",
      "hostname": "{ServiceName}-postgres",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "postgres"
          ]
        }
      },
      "restart": "unless-stopped",
      "environment": [
        "POSTGRES_USER=nora",
        "POSTGRES_PASSWORD={Passwords.3}",
        "POSTGRES_DB=nora",
        "PGDATA=/var/lib/postgresql/data/pgdata"
      ],
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png",
        "cosmos-persistent-env": "POSTGRES_PASSWORD"
      },
      "volumes": [
        {
          "source": "{ServiceName}-postgres-data",
          "target": "/var/lib/postgresql/data",
          "type": "volume"
        }
      ],
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "pg_isready -h 127.0.0.1 -U nora -d nora"
        ],
        "interval": 10,
        "timeout": 5,
        "retries": 10,
        "start_period": 10
      }
    },
    "{ServiceName}-redis": {
      "image": "redis:7-alpine",
      "container_name": "{ServiceName}-redis",
      "hostname": "{ServiceName}-redis",
      "networks": {
        "{ServiceName}_default": {
          "aliases": [
            "redis"
          ]
        }
      },
      "restart": "unless-stopped",
      "labels": {
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}",
        "cosmos-icon": "https://azukaar.github.io/cosmos-servapps-official/servapps/Nora/icon.png"
      },
      "healthcheck": {
        "test": [
          "CMD",
          "redis-cli",
          "ping"
        ],
        "interval": 10,
        "timeout": 5,
        "retries": 10,
        "start_period": 5
      }
    }
  }
}
